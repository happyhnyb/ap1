# ═══════════════════════════════════════════════════════════════
# KYC Platform — Environment Variables
# Copy to .env.local and fill in EVERY value marked REQUIRED.
#
# ⚠️  SECURITY NOTICE: Real API keys were previously committed to
#    this repo in .env and .env.local. ROTATE all secrets:
#      - JWT_SECRET
#      - OPENAI_API_KEY
#      - DATAGOV_API_KEY
#      - MONGODB_URI credentials
# ═══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME="Know Your Commodity"
NODE_ENV=development

# ── MongoDB Atlas ────────────────────────────────────────────
# REQUIRED in production. App runs in demo/in-memory mode if missing.
# mongodb+srv://user:pass@cluster.mongodb.net/kyc?retryWrites=true&w=majority
MONGODB_URI=

# ── Auth (REQUIRED in production) ────────────────────────────
# Generate with: openssl rand -base64 32
# App refuses to start in production without this.
JWT_SECRET=

# ── Mandi Price Service ───────────────────────────────────────
MANDI_SERVICE_URL=http://localhost:4000

# ── Agmarknet Data API ───────────────────────────────────────
# Free registration at https://data.gov.in
DATAGOV_API_KEY=

# ── OpenAI ───────────────────────────────────────────────────
# AI search + predictor insights. Degrades gracefully if missing.
OPENAI_API_KEY=

# ── Weather (optional enrichment) ────────────────────────────
OPENWEATHER_API_KEY=

# ── Stripe Payments ───────────────────────────────────────────
# Get keys at https://dashboard.stripe.com/apikeys
# Test keys start with sk_test_ and pk_test_
# Payments degrade gracefully if missing (subscribe page shows "coming soon")
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Create Products + Prices in Stripe Dashboard, then paste the price IDs here
# e.g. price_1ABC... (monthly) and price_2DEF... (annual)
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
# Public base URL for Stripe redirect URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Email ─────────────────────────────────────────────────────
RESEND_API_KEY=
CONTACT_EMAIL=editor@kyc.news

# ── Object Storage (Cloudflare R2) ───────────────────────────
# Required for image uploads in production.
# In dev, images fall back to public/uploads/ (no R2 needed).
# R2_ENDPOINT: https://<account-id>.r2.cloudflarestorage.com
# Create an API token at: https://dash.cloudflare.com/profile/api-tokens
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public URL for the R2 bucket (custom domain or r2.dev URL)
# e.g. https://media.kyc.news  or  https://pub-xxx.r2.dev
R2_PUBLIC_URL=
