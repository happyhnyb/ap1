{
  "name": "kyc-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "seed": "tsx scripts/seed.ts",
    "ai:nightly": "tsx scripts/ai-nightly.ts",
    "mandi:install": "cd mandi-service && npm install",
    "mandi:dev": "cd mandi-service && npm run dev",
    "mandi:start": "cd mandi-service && npm start"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1028.0",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.2",
    "mongoose": "^9.4.1",
    "next": "^15.5.9",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.1",
    "stripe": "^22.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.3",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "5.7.2",
    "vitest": "^4.1.4"
  }
}
